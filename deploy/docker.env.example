# 复制到仓库根目录并重命名为 .env，供 docker compose 读取（勿提交 git）
# cp deploy/docker.env.example .env

# --- 对外端口：默认 8080，改 80 需本机有权限 ---
WEB_PORT=8080

# --- 与 docker-compose 内 MySQL 一致（若使用 compose 自带 mysql，保持默认即可）---
MYSQL_ROOT_PASSWORD=请改为强密码
MYSQL_DATABASE=koubo
MYSQL_USER=koubo
MYSQL_PASSWORD=请改为强密码

# --- 生产务必设置（登录 JWT）---
JWT_SECRET=请使用 openssl rand -base64 48 生成

# bcrypt 轮数（默认 8，适合 2GB 内存；可改为 10 提高算力成本）
BCRYPT_ROUNDS=8

# --- 可选：浏览器访问的前端 Origin（逗号分隔），不配则 CORS 较宽松 ---
# CORS_ORIGINS=https://你的域名

# --- 若 MySQL 装在宿主机而非 compose：---
# 1) 注释掉 docker-compose.yml 里的 mysql 服务
# 2) 删掉 api.depends_on 里 mysql 段，仅保留 whisper
# 3) 取消下面两行注释并填写宿主机上的库名与用户
# MYSQL_HOST=host.docker.internal
# MYSQL_USER=root

# 数字人图片持久化目录（与 docker-compose 内卷挂载一致，一般无需改）
# DIGITAL_HUMAN_STORAGE_DIR=/workspace/backend/data/digital-humans

# --- Whisper（2GB 内存建议 base；更大可改 medium）---
WHISPER_MODEL=base
WHISPER_PRELOAD=0

# --- 抖音 / 大模型等：参考 backend/.env.example，在下方追加 ---
# OPENAI_API_KEY=
# DY_DOWNLOADER_COOKIE=

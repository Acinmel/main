# 复制到仓库根目录并重命名为 .env，供 docker compose 读取（勿提交 git）
# cp deploy/docker.env.example .env
#
# 数字人 / OpenAI / 抖音 Cookie 等也可只写在 backend/.env（与本地 Nest 一致）；
# docker-compose 已把 backend/.env 作为第二份 env_file 注入 api 容器，无需再抄到根 .env。

# --- 对外端口：默认 8080，改 80 需本机有权限 ---
WEB_PORT=8080

# --- 与 docker-compose 内 MySQL 一致（若使用 compose 自带 mysql，保持默认即可）---
MYSQL_ROOT_PASSWORD=请改为强密码
MYSQL_DATABASE=koubo
MYSQL_USER=koubo
MYSQL_PASSWORD=请改为强密码

# 宿主机映射端口（默认 3306）。若 ECS 上已有本机 MySQL 占 3306，改为 3307 等，避免 bind: address already in use
# MYSQL_HOST_PORT=3307

# --- 生产务必设置（登录 JWT）---
JWT_SECRET=请使用 openssl rand -base64 48 生成

# bcrypt 轮数（默认 8，适合 2GB 内存；可改为 10 提高算力成本）
BCRYPT_ROUNDS=8

# --- 可选：浏览器访问的前端 Origin（逗号分隔），不配则 CORS 较宽松 ---
# CORS_ORIGINS=https://你的域名

# --- 若 MySQL 装在宿主机而非 compose：---
# 1) 注释掉 docker-compose.yml 里的 mysql 服务
# 2) 删掉 api.depends_on 里 mysql 段，仅保留 whisper
# 3) 取消下面两行注释并填写宿主机上的库名与用户
# MYSQL_HOST=host.docker.internal
# MYSQL_USER=root

# 数字人图片持久化目录（与 docker-compose 内卷挂载一致，一般无需改）
# DIGITAL_HUMAN_STORAGE_DIR=/workspace/backend/data/digital-humans

# --- Whisper（2GB 内存建议 base；更大可改 medium）---
WHISPER_MODEL=base
WHISPER_PRELOAD=0

# --- 数字人「自拍照 → 形象图」：三选一，至少配一条，否则前端会提示未配置（实际保存的是原图 mock）---
# 勿写空行 ARK_API_KEY=（会覆盖 backend/.env 里的密钥）。要配时再取消注释并填值，或只写在 backend/.env。
#
# A) 火山方舟（推荐，只配密钥即可，默认已指向北京 endpoint + 图片模型）
# ARK_API_KEY=
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_IMAGE_MODEL=doubao-seedream-5-0-260128
#
# B) jiekou.ai 等 Seedream 兼容（整段 URL + Bearer，需两项同时配置）
# SEEDREAM_HTTP_URL=https://api.jiekou.ai/v3/seedream-4.5
# SEEDREAM_API_KEY=
#
# C) 自建 HTTP 接口（POST JSON，见 backend 代码 DigitalHumanImageService）
# DIGITAL_HUMAN_API_URL=
# DIGITAL_HUMAN_API_KEY=

# --- 抖音 / 其它大模型：参考 backend/.env.example ---
# OPENAI_API_KEY=
# DY_DOWNLOADER_COOKIE=

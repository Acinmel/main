# 复制为 deploy/compose.env（勿提交密钥），启动：
#   docker compose --env-file deploy/compose.env up -d --build

# ----- 抖音源视频 / dy-downloader（首页「获取视频信息」等；不上线抖音可留空）-----
DY_DOWNLOADER_COOKIE=
# DY_DOWNLOADER_FETCH_TIMEOUT_MS=120000

# ----- 服务端保存 MP4 目录（容器内路径；默认与 docker-compose 卷一致）-----
# VIDEO_SAVE_DIR=/data/download-video

# ----- FFmpeg（api 镜像已带 /usr/bin/ffmpeg；一般无需改）-----
# FFMPEG_BIN=/usr/bin/ffmpeg

# ----- Whisper（Compose 已写死 whisper 服务名；此处仅调模型）-----
# WHISPER_MODEL=medium
# WHISPER_PRELOAD=0

# ----- 入口 -----
# WEB_PORT=8080

# ----- 可选 OpenAI（改写等）-----
# OPENAI_API_KEY=

# ----- 前后端分离 / 公网 CORS（Web 与 API 不同源时填写；留空则任意 Origin，与开发一致）-----
# CORS_ORIGINS=https://www.example.com,https://app.example.com

# --- 公网 / 反代（可选）---
# 逗号分隔的浏览器 Origin，如 https://www.example.com,https://app.example.com
# 不设置时：与开发一致，CORS 为 origin: true（任意来源）
# CORS_ORIGINS=
# 设为 1 或 true 时：信任反向代理的 X-Forwarded-*（与 Nginx 同机部署时建议开启）
# TRUST_PROXY=

# OpenAI 兼容（可用于改写 / 未来 TTS / Whisper 同 key）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=60000

# 第二步「生成视频」大模型（OpenAI 兼容 Chat Completions）；不填则回退到上面的 OPENAI_*
# LLM_API_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=
# LLM_MODEL=gpt-4o-mini
# LLM_TIMEOUT_MS=120000
# 首页预览用演示 MP4；设为 none 则不返回地址
# GENERATE_VIDEO_DEMO_MP4_URL=

# --- jiekou Seedance 1.5 Pro 图生视频（异步，POST /v3/async/seedance-v1.5-pro-i2v）---
# 联调：POST /api/v1/tools/seedance-i2v-async，body 至少含 image、prompt；其余字段见 SeedanceI2vService
# SEEDANCE_I2V_API_URL=https://api.jiekou.ai/v3/async/seedance-v1.5-pro-i2v
# SEEDANCE_I2V_API_KEY=
# 未单独配置时可回退 JIEKOU_API_KEY、SEEDREAM_API_KEY
# JIEKOU_API_KEY=
# SEEDANCE_I2V_HTTP_TIMEOUT_MS=120000
# 以下为请求体默认值（可被 body 覆盖）：fps、ratio、duration、resolution、watermark、camera_fixed、generate_audio、execution_expires_after
# SEEDANCE_I2V_FPS=24
# SEEDANCE_I2V_RATIO=9:16
# SEEDANCE_I2V_DURATION=5
# SEEDANCE_I2V_RESOLUTION=1080p
# SEEDANCE_I2V_WATERMARK=1
# SEEDANCE_I2V_CAMERA_FIXED=1
# SEEDANCE_I2V_GENERATE_AUDIO=1
# SEEDANCE_I2V_EXECUTION_EXPIRES_AFTER=86400
# SEEDANCE_I2V_SEED=
# SEEDANCE_I2V_LAST_IMAGE=
# SEEDANCE_I2V_SERVICE_TIER=

# --- 数字人自拍照→形象图（多选一，优先级自上而下）---
#
# A) jiekou.ai 等「整段 URL」Seedream（如 /v3/seedream-4.5）：与方舟不同，body 无 model/response_format
# SEEDREAM_HTTP_URL=https://api.jiekou.ai/v3/seedream-4.5
# SEEDREAM_API_KEY=
# SEEDREAM_IMAGE_SIZE=2K
# SEEDREAM_IMAGE_WATERMARK=1
# SEEDREAM_HTTP_TIMEOUT_MS=300000
# 组图：与方舟一致可回退 ARK_SEQUENTIAL_*；或单独设 SEEDREAM_SEQUENTIAL_IMAGE_GENERATION / SEEDREAM_SEQUENTIAL_MAX_IMAGES
# SEEDREAM_SEQUENTIAL_IMAGE_GENERATION=auto
# SEEDREAM_SEQUENTIAL_MAX_IMAGES=3
# 仅在有值时发送：optimize_prompt_options.mode（值以控制台文档为准）
# SEEDREAM_OPTIMIZE_PROMPT_MODE=
# 参考图：默认 image 为 data URL 字符串数组；若接口要求对象数组则 SEEDREAM_IMAGE_ITEM_STYLE=object，键名默认 image，可改 SEEDREAM_IMAGE_OBJECT_KEY
# SEEDREAM_IMAGE_ITEM_STYLE=string
# SEEDREAM_IMAGE_OBJECT_KEY=image
#
# B) 火山方舟图片生成：ARK_API_KEY；POST {ARK_BASE_URL}/images/generations
#    会携带用户自拍参考图 image: [data:image/...;base64,...]，sequential_image_generation 默认 auto（设 disabled 可关组图）
# ARK_API_KEY=
# 默认 https://ark.cn-beijing.volces.com/api/v3（与路径 /images/generations 拼接；若曾写 …/v3/v1 仍兼容）
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_IMAGE_MODEL=doubao-seedream-5-0-260128
# ARK_IMAGE_SIZE=2K
# ARK_IMAGE_WATERMARK=1
# ARK_IMAGE_TIMEOUT_MS=300000
# 组图：auto | disabled（默认 auto）
# ARK_SEQUENTIAL_IMAGE_GENERATION=auto
# sequential_image_generation_options.max_images，范围 1～15（默认 3）
# ARK_SEQUENTIAL_MAX_IMAGES=3
# 追加在风格预设后的中文说明（可选，不填则用内置）
# ARK_IMAGE_PROMPT_SUFFIX=
#
# 火山方舟「图生视频」异步任务：POST /api/v3/contents/generations/tasks（联调：POST /api/v1/tools/ark-i2v-task）
# 可与上图共用 ARK_API_KEY；也可单独设 ARK_I2V_API_KEY
# ARK_I2V_MODEL=doubao-seedance-1-5-pro-251215
# ARK_I2V_HTTP_TIMEOUT_MS=120000
# 首页「预览成片」轮询方舟任务：总时长与间隔（毫秒）
# ARK_I2V_POLL_MAX_MS=600000
# ARK_I2V_POLL_INTERVAL_MS=2500
#
# C) 自定义网关：POST JSON（ content + image_base64 + mime_type + style_id ）
# DIGITAL_HUMAN_API_URL=
# DIGITAL_HUMAN_API_KEY=
# DIGITAL_HUMAN_API_TIMEOUT_MS=120000
# 落盘目录（默认 backend/data/digital-humans）；元数据见下方 MySQL / SQLite
# DIGITAL_HUMAN_STORAGE_DIR=

# --- 持久化（二选一）---
# 设置 MYSQL_DATABASE 后使用 MySQL（docker-compose 已包含 mysql 服务）；不设置则回退 SQLite 单文件。
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=koubo
# MYSQL_PASSWORD=
# MYSQL_DATABASE=koubo
# 未使用 MySQL 时：SQLite 路径（默认 backend/data/app.db）
# SQLITE_PATH=

# 登录 JWT 签名密钥（POST /api/v1/auth/register、/login）；生产环境务必设置强随机值
# JWT_SECRET=
# 从远端 URL 拉取生成图的最大字节数（默认约 15MB）
# DIGITAL_HUMAN_IMAGE_MAX_BYTES=15728640

# 线上一体化部署见仓库根目录 DEPLOY.md 与 docker-compose.yml（内置 whisper + yt-dlp，无需用户本机安装）
#
# --- Python Whisper 联调顺序（本地开发）---
# ① 启动 Whisper：仓库根目录 npm run whisper:dev（或 backend 目录 npm run whisper）
#    依赖：ffmpeg + pip install -r backend/whisper-python-service/requirements.txt，详见 backend/whisper-python-service/README.md
#    或仅起容器：npm run whisper:docker（根目录）
# ② 配置主后端（本文件）：WHISPER_HTTP_URL 指向转写地址
# ③ 验证存活：GET /api/v1/tools/whisper-health（或首页「检查 Python 服务」）
# ④ 上传转写：POST /api/v1/tools/transcribe-whisper → 后端转发 Python 并内存保存 transcript
# 本机直跑 Whisper 时示例：
WHISPER_HTTP_URL=http://127.0.0.1:8010/transcribe
WHISPER_HTTP_TIMEOUT_MS=600000
# 送 Whisper 的 multipart 体积上限（字节）；不填则默认约 200MB（与链接下载、Multer 一致）
# WHISPER_MEDIA_MAX_BYTES=209715200
# 健康检查 GET 地址；不填则由 WHISPER_HTTP_URL 推导（末段路径换为 health）
# WHISPER_HTTP_HEALTH_URL=http://127.0.0.1:8010/health
WHISPER_HTTP_HEALTH_TIMEOUT_MS=10000
# 可选：WHISPER_HTTP_TOKEN=your-secret

# ASR：mock | whisper（任务流水线内占位；首页「解析视频」走 transcribe-whisper → WHISPER_HTTP_URL）
ASR_MODE=mock

# 数字人 HTTP 占位（有值时 AvatarAiService 会带上 endpoint 字段）
AVATAR_HTTP_ENDPOINT=

# 视频页抓取（非 AI）：自定义 UA / 超时（毫秒）
# VIDEO_FETCH_USER_AGENT=Mozilla/5.0 ...
# VIDEO_FETCH_TIMEOUT_MS=18000
# 从链接解析媒体后下载体积上限（字节），与 Whisper 上传上限对齐（默认约 200MB）
# VIDEO_MEDIA_MAX_BYTES=209715200

# 视频 → 抽音轨再送 Whisper（backend/ffmpeg/bin）；不填则依次尝试此处、PATH
# 本机 gyan 静态库解压后请将 ffmpeg.exe 放到 backend/ffmpeg/bin/ffmpeg.exe
# Docker 镜像内置：FFMPEG_BIN=/usr/bin/ffmpeg
# FFMPEG_BIN=C:\\\\path\\\\to\\\\ffmpeg.exe

# 链接转写推荐：yt-dlp（https://github.com/yt-dlp/yt-dlp ）
# 方式 A：安装官方发行版后填写可执行文件绝对路径（Windows 示例：YTDLP_BIN=C:\\Tools\\yt-dlp\\yt-dlp.exe）
YTDLP_BIN=
# 方式 B：仓库内已有 yt-dlp-master 时可不填 YTDLP_BIN；后端会向上探测目录并用 python -m yt_dlp（需 pip install -e ./yt-dlp-master 等）
# YT_DLP_SOURCE_DIR=../yt-dlp-master
# PYTHON_BIN=python
# Windows 仅有 py 启动器：PYTHON_BIN=py 且 YTDLP_PYTHON_ARGS=-3
# YTDLP_PYTHON_ARGS=-3
YTDLP_TIMEOUT_MS=300000
# 从本机已登录浏览器读 Cookie，提高抖音等成功率（chrome / edge / firefox …）
# YTDLP_COOKIES_FROM_BROWSER=chrome
# YTDLP_PROXY=http://127.0.0.1:7890

# 源视频「保存到本机」目录（首页「获取视频信息」抖音分支会写入此目录；不存在则自动创建）
# Windows 默认：C:\\downloadVideo；非 Windows 默认：~/downloadVideo
# VIDEO_SAVE_DIR=C:\\downloadVideo

# --- 抖音下载（必选）：仓库内 backend/DY-DOWNLOADER（npm 名 dy-downloader），仅走 Cookie，不走 yt-dlp ---
# 将浏览器复制的整段 Cookie 写入本机 backend/.env（勿把真实值提交 git）
# DY_DOWNLOADER_COOKIE=
# DY_DOWNLOADER_FETCH_TIMEOUT_MS=120000
